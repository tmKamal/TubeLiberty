{
  "manifest_version": 3,
  "name": "TubeLiberty",
  "version": "1.0",
  "description": "Set daily watch time and shorts limits for YouTube. Track streaks, build better habits.",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "serviceWorker.js"
  },
  "action": {
    "default_popup": "infoPopup.html",
    "default_icon": {
      "16": "images/popup-16.png",
      "48": "images/popup-48.png",
      "128": "images/popup-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanelYtSummary.html"
  },
  "content_scripts": [
    {
      "js": ["shared/constants.js", "contentScript.js"],
      "css": ["styles.css"],
      "matches": ["https://*.youtube.com/*"]
    }
  ],
  "permissions": ["storage", "tabs", "sidePanel", "alarms"],
  "host_permissions": ["https://*.youtube.com/*"],
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles.css", "common.css"],
      "matches": ["https://*.youtube.com/*"]
    }
  ]
}
